# 키움증권 OpenAPI 인증 정보
# https://openapi.kiwoom.com 에서 발급
KIWOOM_APP_KEY=your_app_key_here
KIWOOM_SECRET_KEY=your_secret_key_here

# 실계좌 번호 (노출 주의 - .gitignore에서 .env 파일 제외 필수)
KIWOOM_ACCOUNT_NO=12345678901

# API 서버 (실계좌: api.kiwoom.com / 모의: mockapi.kiwoom.com)
KIWOOM_HOST=https://api.kiwoom.com

# 보안 설정 (기본값 유지 권장)
READ_ONLY_MODE=true
ORDER_ENABLED=false

# 디버그 (운용 환경에서는 false)
DEBUG=false
